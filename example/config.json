    "displayName": "Freeway",
    "tagline": "Your on-ramp to Phoenix's tech ecosystem",
    "description": "Freeway is the connective tissue of Phoenix's tech ecosystem. Not a coworking space, not a VC fund, not a job board — it's the infrastructure that makes the ecosystem navigable. The visual language reflects that: energetic but grounded, vibrant but never loud, built to connect.",
    "url": "freewayphx.com",
    "byline": "built by the stack lab",
    "version": "1.0",
    "date": "March 2026"
  },
  "fonts": {
    "display": {
      "family": "Commissioner",
      "googleImport": "Commissioner:wght@300;400;500;600;700",
      "description": "Variable geometric sans-serif. Structured, authoritative, modern. Display and headings."
    },
    "body": {
      "family": "Ubuntu",
      "googleImport": "Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,400",
      "description": "Humanist sans-serif with rounded terminals. Warm, legible, approachable. Body text and UI."
    }
  },
