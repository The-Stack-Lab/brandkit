  "sections": {
    "gradients": "The purple-to-coral gradient is the signature visual element. It captures the energy and movement of the brand — the on-ramp from one thing to the next.",
    "gradientTextDemo": "The freeway connects everything.",
    "logos": "Download logo files for use across web, social, and print materials. Select format and size, then download.",
    "components": "Buttons are pill-shaped across all variants. Sizes scale padding and font, not border-radius.",
    "spacing": "4px base unit. All spacing values are multiples of 4, aligned with Tailwind's default scale.",
    "variables": "Maps to the shadcn/ui variable structure. All values in oklch for Tailwind CSS 4. Click any line to copy."
  },
  "hierarchy": [
    { "class": "h-primary", "label": "Primary", "colorVar": "--ink", "colorName": "Ink", "hex": "#1A1625", "description": "Primary text uses Ink at full opacity. Body copy, headings, and content where readability is critical." },
    { "class": "h-secondary", "label": "Secondary", "colorVar": "--graphite", "colorName": "Graphite", "hex": "#3D3551", "description": "Secondary text uses Graphite. Descriptions, supporting information, and labels that recede behind primary." },
    { "class": "h-tertiary", "label": "Tertiary", "colorVar": "--slate", "colorName": "Slate", "hex": "#6E6584", "description": "Tertiary text uses Slate. Captions, timestamps, footnotes, and metadata." },
